        "@babel/preset-env": "^7.18.6",
        "@babel/register": "^7.18.6",
        "@types/node": "^24.9.2",
        "@typescript-eslint/eslint-plugin": "^8.46.3",
        "@typescript-eslint/parser": "^8.46.3",
        "babel-loader": "^8.2.5",
        "babel-preset-preact": "^2.0.0",
        "chalk": "^4.1.2",
        "clean-webpack-plugin": "^4.0.0",
        "compression-webpack-plugin": "^10.0.0",
        "concurrently": "^7.2.2",
        "core-js": "^3.23.3",
        "cross-env": "^7.0.3",
        "css-loader": "^6.7.1",
